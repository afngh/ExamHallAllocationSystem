# ── ExamSeat Pro — Backend Environment Variables ──────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in values below
# 3. Never commit .env to version control (it's in .gitignore)

# ── MySQL ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=examhall_db
DB_POOL_MAX=10

# ── App ────────────────────────────────────────────────────────
PORT=3306
NODE_ENV=development

# ── JWT ────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=8h

# ── CORS ───────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
